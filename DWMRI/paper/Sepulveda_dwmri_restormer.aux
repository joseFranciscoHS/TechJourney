\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Hybrid RGS training and inference pipeline. \textbf  {Training (top):} From $G$ diffusion-weighted volumes, a target volume $t$ and context set $C_t$ of $K-1$ gradients are randomly sampled. The context volumes remain unmasked while the target undergoes Bernoulli masking ($p=0.3$) to create $\tilde  {y}_t$. These are concatenated into a $K$-channel input stack $z_t$ (target at channel $K-1$) and processed by the denoiser $f_\theta $ (DRCNet or Restormer). The self-supervised loss (Eq.\nobreakspace  {}4) is computed only on masked voxel locations $\Omega _m$, enforcing a blind-spot objective at supervised masked sites; the J-invariance guarantee applies to the training loss at those locations, not to every voxel of the final reconstruction. \textbf  {Inference (bottom, dashed):} Each target volume is reconstructed through Monte Carlo ensemble averaging. For $N_c$ random context draws and $N_p$ spatial mask realizations per context, the model generates $N_c \times N_p$ predictions which are averaged to produce the final reconstruction $\bar  {y}_t$ (Eq.\nobreakspace  {}5). This ensemble is a stochastic masked ensemble rather than a strictly voxel-wise J-invariant estimator, because each voxel is unmasked in many ensemble members. Default D-Brain configuration: $K=16$, $N_c=16$, $N_p=12$; Stanford HARDI: $N_p=23$.}}{15}{figure.2}\protected@file@percent }
\newlabel{fig:hybrid_rgs_pipeline}{{2}{15}{Hybrid RGS training and inference pipeline. \textbf {Training (top):} From $G$ diffusion-weighted volumes, a target volume $t$ and context set $C_t$ of $K-1$ gradients are randomly sampled. The context volumes remain unmasked while the target undergoes Bernoulli masking ($p=0.3$) to create $\tilde {y}_t$. These are concatenated into a $K$-channel input stack $z_t$ (target at channel $K-1$) and processed by the denoiser $f_\theta $ (DRCNet or Restormer). The self-supervised loss (Eq.~4) is computed only on masked voxel locations $\Omega _m$, enforcing a blind-spot objective at supervised masked sites; the J-invariance guarantee applies to the training loss at those locations, not to every voxel of the final reconstruction. \textbf {Inference (bottom, dashed):} Each target volume is reconstructed through Monte Carlo ensemble averaging. For $N_c$ random context draws and $N_p$ spatial mask realizations per context, the model generates $N_c \times N_p$ predictions which are averaged to produce the final reconstruction $\bar {y}_t$ (Eq.~5). This ensemble is a stochastic masked ensemble rather than a strictly voxel-wise J-invariant estimator, because each voxel is unmasked in many ensemble members. Default D-Brain configuration: $K=16$, $N_c=16$, $N_p=12$; Stanford HARDI: $N_p=23$}{figure.2}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {3.5}Inference}{15}{subsection.3.5}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Restormer3D internal architecture for Hybrid RGS. A 3-level encoder-decoder with transformer blocks at each stage. The encoder progressively downsamples spatial dimensions ($\times 2$ per level) while doubling channel count ($\text  {dim}\rightarrow 2\!\cdot \!\text  {dim}\rightarrow 4\!\cdot \!\text  {dim}$, with $\text  {dim}=12$). Each level contains $N$ transformer blocks combining Multi-DConv Head Transposed Self-Attention (MDTA, $h$ heads) and Gated-DConv Feed-Forward Networks (GDFN). The decoder mirrors the encoder with skip connections (dashed gray arrows) and channel-reduction convolutions after concatenation. Refinement blocks and a learned affine output head ($\gamma _{\mathrm  {out}}\!\cdot \!x\!+\!\beta _{\mathrm  {out}}$) produce the single-channel denoised volume. Optional FiLM conditioning (yellow boxes) modulates features at three stages using the target gradient's acquisition metadata $[\qopname  \relax o{cos}_x, \qopname  \relax o{cos}_y, \qopname  \relax o{cos}_z, b_{\text  {norm}}]$; see Table\nobreakspace  {}\ref  {tab:film_ablation} for evaluation. The 2D counterpart, Restormer-2D, shares this same topology (Figure\nobreakspace  {}\ref  {fig:backbone_comparison}) but with 2D \texttt  {Conv2d}/MDTA/GDFN operations and \texttt  {PixelUnshuffle}/\texttt  {PixelShuffle} resampling in place of \texttt  {Conv3d}/volumetric MDTA and strided \texttt  {Conv3d}/\texttt  {ConvTranspose3d}.}}{16}{figure.3}\protected@file@percent }
\newlabel{fig:restormer3d_arch}{{3}{16}{Restormer3D internal architecture for Hybrid RGS. A 3-level encoder-decoder with transformer blocks at each stage. The encoder progressively downsamples spatial dimensions ($\times 2$ per level) while doubling channel count ($\text {dim}\rightarrow 2\!\cdot \!\text {dim}\rightarrow 4\!\cdot \!\text {dim}$, with $\text {dim}=12$). Each level contains $N$ transformer blocks combining Multi-DConv Head Transposed Self-Attention (MDTA, $h$ heads) and Gated-DConv Feed-Forward Networks (GDFN). The decoder mirrors the encoder with skip connections (dashed gray arrows) and channel-reduction convolutions after concatenation. Refinement blocks and a learned affine output head ($\gamma _{\mathrm {out}}\!\cdot \!x\!+\!\beta _{\mathrm {out}}$) produce the single-channel denoised volume. Optional FiLM conditioning (yellow boxes) modulates features at three stages using the target gradient's acquisition metadata $[\cos _x, \cos _y, \cos _z, b_{\text {norm}}]$; see Table~\ref {tab:film_ablation} for evaluation. The 2D counterpart, Restormer-2D, shares this same topology (Figure~\ref {fig:backbone_comparison}) but with 2D \texttt {Conv2d}/MDTA/GDFN operations and \texttt {PixelUnshuffle}/\texttt {PixelShuffle} resampling in place of \texttt {Conv3d}/volumetric MDTA and strided \texttt {Conv3d}/\texttt {ConvTranspose3d}}{figure.3}{}}
\@writefile{tdo}{\contentsline {todo}{new 2026-07-14 Original Restormer 2D vs 3D vs other backbones}{17}{section*.6}\protected@file@percent }
\pgfsyspdfmark {pgfid25}{20071710}{43232280}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Backbone comparison for the capacity-dimensionality ablation. Restormer3D and Restormer-2D are same-family volumetric/slice-wise ports of Zamir et al.'s Restormer \cite  {restormer}, differing only in the dimensionality of their MDTA/GDFN operations, their resampling (\texttt  {Conv3d}/\texttt  {ConvTranspose3d} vs \texttt  {PixelUnshuffle}/\texttt  {PixelShuffle}), and the presence of FiLM conditioning (3D only); this pair isolates spatial dimensionality as a controlled experimental factor within the Restormer family. Res-CNN-2D is an independent generic residual CNN with no attention or hierarchical structure, included as a lower-capacity baseline rather than an architectural port. See Table\nobreakspace  {}\ref  {tab:3d_vs_2d} for the corresponding quantitative ablation.}}{17}{figure.4}\protected@file@percent }
\newlabel{fig:backbone_comparison}{{4}{17}{Backbone comparison for the capacity-dimensionality ablation. Restormer3D and Restormer-2D are same-family volumetric/slice-wise ports of Zamir et al.'s Restormer \cite {restormer}, differing only in the dimensionality of their MDTA/GDFN operations, their resampling (\texttt {Conv3d}/\texttt {ConvTranspose3d} vs \texttt {PixelUnshuffle}/\texttt {PixelShuffle}), and the presence of FiLM conditioning (3D only); this pair isolates spatial dimensionality as a controlled experimental factor within the Restormer family. Res-CNN-2D is an independent generic residual CNN with no attention or hierarchical structure, included as a lower-capacity baseline rather than an architectural port. See Table~\ref {tab:3d_vs_2d} for the corresponding quantitative ablation}{figure.4}{}}
